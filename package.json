{
  "name": "localzada",
  "version": "1.1.0",
  "description": "Run and share local servers with one command — لتشغيل ومشاركة سيرفراتك المحلية بأمر واحد",
  "bin": {
    "localzada": "./dist/cli.js",
    "lz": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "tsx scripts/test-yaml.ts",
    "test:preview": "tsx scripts/preview-errors.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "localhost",
    "tunnel",
    "cloudflare",
    "share",
    "dev-tools",
    "cli",
    "ngrok-alternative",
    "webhook",
    "developer-experience",
    "typescript"
  ],
  "author": {
    "name": "Mohammed (Ai RawayieAldhaka)",
    "url": "https://github.com/medissaoui711"
  },
  "license": "MIT",
  "homepage": "https://github.com/medissaoui711/localzada-host#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medissaoui711/localzada-host.git"
  },
  "bugs": {
    "url": "https://github.com/medissaoui711/localzada-host/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "execa": "^9.5.1",
    "node-machine-id": "^1.1.12",
    "ora": "^8.1.1",
    "pidusage": "^4.0.0",
    "tree-kill": "^1.2.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pidusage": "^2.0.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
